PORT=5000
NODE_ENV=production

# MongoDB Atlas (replace with your connection string)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/smartopd

# JWT
JWT_SECRET=CHANGE_THIS_TO_A_STRONG_RANDOM_SECRET
JWT_EXPIRES_IN=7d

# Email (Gmail SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# Fast2SMS (India) — OTP delivery
FAST2SMS_API_KEY=

# OpenAI API — voice pipeline
#   Vosk (browser, wake word) → gpt-4o-transcribe (STT) → gpt-5 (assistant) → gpt-5 (medical) → gpt-4o-mini-tts
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL_MEDICAL=gpt-5
OPENAI_MODEL_ASSISTANT=gpt-5
OPENAI_MODEL_NORMAL=gpt-5
OPENAI_MODEL_STT=gpt-4o-transcribe
OPENAI_MODEL_TTS=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy

# Raspberry-Pi vitals kiosk shared secret (sent as X-Kiosk-Key header)
KIOSK_DEVICE_KEY=CHANGE_THIS_TO_A_LONG_RANDOM_STRING

# Frontend URLs (comma-separated: web dashboard + patient app)
CLIENT_URL=https://mediassist.vercel.app,capacitor://localhost,https://localhost

# Demo Mode (set true for demo seeding on startup)
DEMO_MODE=true
