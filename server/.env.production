PORT=5000
NODE_ENV=production

# MongoDB Atlas (replace with your connection string)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/smartopd

# JWT
JWT_SECRET=CHANGE_THIS_TO_A_STRONG_RANDOM_SECRET
JWT_EXPIRES_IN=7d

# Email (Gmail SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# Twilio SMS (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# OpenAI API
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL_MEDICAL=gpt-4.1
OPENAI_MODEL_NORMAL=gpt-4.1-mini

# Frontend URLs (comma-separated: web dashboard + patient app)
CLIENT_URL=https://your-app.onrender.com,capacitor://localhost,https://localhost

# Demo Mode (disable in production)
DEMO_MODE=false
